#!/bin/sh
# pre-push hook: 运行完整测试和构建检查
# 遵循宪法第七条：依赖安全原则

# 添加 Go bin 到 PATH
export PATH="$PATH:$(go env GOPATH)/bin"

echo "==> Running pre-push checks..."

# 工具安装函数
install_if_missing() {
    cmd="$1"
    install_cmd="$2"
    if ! command -v "$cmd" >/dev/null 2>&1 && ! command -v "${cmd}.exe" >/dev/null 2>&1; then
        echo "Installing $cmd..."
        eval "$install_cmd" || { echo "FAIL: failed to install $cmd"; exit 1; }
    fi
}

# 1. 全量测试
echo "[1/4] Running tests..."
go test -v ./...
if [ $? -ne 0 ]; then
    echo "FAIL: tests failed"
    exit 1
fi

# 2. 构建检查
echo "[2/4] Building..."
go build ./...
if [ $? -ne 0 ]; then
    echo "FAIL: build failed"
    exit 1
fi

# 3. golangci-lint
echo "[3/4] Running golangci-lint..."
install_if_missing "golangci-lint" "go install github.com/golangci/golangci-lint/cmd/golangci-lint@latest"
"$(go env GOPATH)/bin/golangci-lint.exe" run --timeout=5m ./...
if [ $? -ne 0 ]; then
    echo "FAIL: golangci-lint failed"
    exit 1
fi

# 4. govulncheck 独立检查（双重保障）
echo "[4/4] Running govulncheck..."
install_if_missing "govulncheck" "go install golang.org/x/vuln/cmd/govulncheck@latest"
"$(go env GOPATH)/bin/govulncheck.exe" ./...
if [ $? -ne 0 ]; then
    echo "FAIL: vulnerabilities detected"
    exit 1
fi

echo "==> pre-push checks passed"
exit 0