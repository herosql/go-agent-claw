#!/bin/sh
# pre-commit hook: 运行代码检查和漏洞扫描
# 遵循宪法第七条：依赖安全原则

echo "==> Running pre-commit checks..."

# 1. go vet 检查
echo "[1/3] Running go vet..."
go vet ./...
if [ $? -ne 0 ]; then
    echo "FAIL: go vet failed"
    exit 1
fi

# 2. golangci-lint 检查（包含 govulncheck）
echo "[2/3] Running golangci-lint..."
if command -v golangci-lint >/dev/null 2>&1; then
    golangci-lint run --timeout=5m
    if [ $? -ne 0 ]; then
        echo "FAIL: golangci-lint failed"
        exit 1
    fi
else
    echo "[SKIP] golangci-lint not installed, skipping"
fi

# 3. 敏感信息检查（防止提交密钥）
echo "[3/3] Checking for hardcoded secrets..."
if grep -rE '(api[_-]?key|password|secret|token)\s*[:=]\s*["\047][a-zA-Z0-9]{16,}' --include="*.go" . 2>/dev/null; then
    echo "FAIL: Potential hardcoded secret detected"
    exit 1
fi

echo "==> pre-commit checks passed"
exit 0